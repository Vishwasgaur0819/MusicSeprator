# Copy to android/keystore.properties and fill in after generating a release keystore.
# Do not commit keystore.properties or *.keystore (except debug.keystore).
#
# Generate a keystore (from project root):
#   powershell -ExecutionPolicy Bypass -File scripts/generate-release-keystore.ps1
#
storeFile=musicapp-release.keystore
storePassword=YOUR_STORE_PASSWORD
keyAlias=musicapp
keyPassword=YOUR_KEY_PASSWORD
