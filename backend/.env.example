PORT=8787
HOST=0.0.0.0
PUBLIC_BASE_URL=http://localhost:8787

# Optional bearer token; if set, app must send Authorization: Bearer <token>
API_TOKEN=

# Max source audio upload size in MB
MAX_UPLOAD_MB=30

# Local data folder for uploads and generated stems
DATA_DIR=./data

# Engine: ffmpeg (default, approximation) or demucs (higher quality)
SEPARATION_ENGINE=ffmpeg

# Used only when SEPARATION_ENGINE=demucs.
# Example:
# DEMUCS_CMD=python -m demucs
DEMUCS_CMD=

